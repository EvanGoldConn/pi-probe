#!/bin/bash
# Forces wlan0 into hotspot mode immediately.
# Tears down any active connection cleanly before starting hostapd.
# Logs to /tmp/wifi-hotspot.log

LOG=/tmp/wifi-hotspot.log
echo "[wifi-hotspot] Starting at $(date)" > $LOG

echo "[wifi-hotspot] Tearing down wlan0..." | tee -a $LOG
systemctl stop wpa_supplicant@wlan0.service 2>/dev/null
systemctl stop wpa_supplicant.service 2>/dev/null
systemctl stop hostapd 2>/dev/null
systemctl stop dnsmasq 2>/dev/null
pkill -x wpa_supplicant 2>/dev/null
pkill -x dhcpcd 2>/dev/null
networkctl down wlan0 2>/dev/null
ip link set wlan0 down
ip addr flush dev wlan0
rm -f /var/run/wpa_supplicant/wlan0 2>/dev/null
rm -f /tmp/wlan0-manual 2>/dev/null
sleep 2

echo "[wifi-hotspot] Starting hostapd..." | tee -a $LOG
ip addr add 192.168.4.1/24 dev wlan0
ip link set wlan0 up
systemctl unmask hostapd 2>/dev/null

for i in 1 2 3 4 5; do
    systemctl start hostapd
    sleep 3
    if systemctl is-active --quiet hostapd; then
        systemctl start dnsmasq
        echo "[wifi-hotspot] Hotspot active -- SSID: PiRecon, IP: 192.168.4.1" | tee -a $LOG
        exit 0
    fi
    echo "[wifi-hotspot] hostapd attempt $i failed -- retrying..." | tee -a $LOG
    systemctl stop hostapd 2>/dev/null
    sleep 2
done

echo "[wifi-hotspot] ERROR: hostapd failed to start after 5 attempts" | tee -a $LOG
exit 1
