#!/bin/bash
# Set Pi system time manually.
# Usage: sudo fix-time "2026-06-06 01:30:00"
# Or call pi-sync-time from the Mac to push time automatically.

if [ -n "$1" ]; then
    date -s "$1"
    echo "Time updated: $(date)"
else
    echo "Usage: sudo fix-time \"YYYY-MM-DD HH:MM:SS\""
    echo "Or run pi-sync-time from your Mac to sync automatically."
fi
