#!/bin/bash
# Connects wlan0 to a network by SSID and PSK for the current session only.
# Credentials are never saved -- reboot returns to hotspot.
# On failure, automatically returns to hotspot mode.
# Usage: sudo wifi-connect "SSID" "PSK"

if [ -z "$1" ] || [ -z "$2" ]; then
    echo "Usage: sudo wifi-connect \"SSID\" \"PSK\""
    exit 1
fi

SSID="$1"
PSK="$2"
MANUAL_FLAG=/tmp/wlan0-manual
LOG=/tmp/wifi-connect.log

echo "[wifi-connect] Starting at $(date)" > $LOG

# Detect current state
CURRENT_IP=$(ip addr show wlan0 2>/dev/null | grep "inet " | awk '{print $2}')
if echo "$CURRENT_IP" | grep -q "192.168.4.1"; then
    CURRENT_STATE="hotspot (PiRecon)"
elif [ -n "$CURRENT_IP" ]; then
    CURRENT_SSID=$(wpa_cli -i wlan0 status 2>/dev/null | grep "^ssid=" | cut -d= -f2)
    CURRENT_STATE="WiFi ($CURRENT_SSID, $CURRENT_IP)"
else
    CURRENT_STATE="disconnected"
fi

echo "[wifi-connect] Current state: $CURRENT_STATE"
echo "[wifi-connect] Target: $SSID"
echo ""
read -p "Disconnect from $CURRENT_STATE and connect to $SSID? [y/N] " CONFIRM
if [ "$CONFIRM" != "y" ] && [ "$CONFIRM" != "Y" ]; then
    echo "[wifi-connect] Aborted."
    exit 0
fi

echo "[wifi-connect] Tearing down wlan0..." | tee -a $LOG
systemctl stop wpa_supplicant@wlan0.service 2>/dev/null
systemctl stop hostapd 2>/dev/null
systemctl stop dnsmasq 2>/dev/null
pkill -x wpa_supplicant 2>/dev/null
pkill -x dhcpcd 2>/dev/null
networkctl down wlan0 2>/dev/null
ip link set wlan0 down
ip addr flush dev wlan0
rm -f /var/run/wpa_supplicant/wlan0 2>/dev/null
sleep 2

echo "[wifi-connect] Writing temp config for $SSID..." | tee -a $LOG
tee /tmp/wpa-temp.conf << WPAEOF > /dev/null
ctrl_interface=DIR=/var/run/wpa_supplicant GROUP=netdev
update_config=1

network={
    ssid="$SSID"
    psk="$PSK"
}
WPAEOF

echo "[wifi-connect] Starting wpa_supplicant..." | tee -a $LOG
ip link set wlan0 up
wpa_supplicant -B -i wlan0 -c /tmp/wpa-temp.conf

echo "[wifi-connect] Waiting for association..." | tee -a $LOG
ASSOCIATED=0
for i in $(seq 1 30); do
    STATE=$(wpa_cli -i wlan0 status 2>/dev/null | grep wpa_state | cut -d= -f2)
    if [ "$STATE" = "COMPLETED" ]; then
        echo "[wifi-connect] Associated after ${i}s" | tee -a $LOG
        ASSOCIATED=1
        break
    fi
    sleep 1
done

if [ "$ASSOCIATED" = "0" ]; then
    echo "[wifi-connect] Failed -- could not associate" | tee -a $LOG
    echo "[wifi-connect] Returning to hotspot..."
    pkill -x wpa_supplicant 2>/dev/null
    rm -f /tmp/wpa-temp.conf
    systemctl restart wlan0-manager.service
    exit 1
fi

echo "[wifi-connect] Requesting DHCP..." | tee -a $LOG
dhcpcd wlan0 &
sleep 10
IP=$(ip addr show wlan0 2>/dev/null | grep "inet " | grep -v "192.168.4" | awk '{print $2}' | head -1)

if [ -n "$IP" ]; then
    echo "$SSID" > $MANUAL_FLAG
    echo "[wifi-connect] Connected -- wlan0 IP: $IP" | tee -a $LOG
    echo "[wifi-connect] Connected to $SSID at $IP"
    echo "[wifi-connect] Watchdog will return to hotspot if connection drops"
else
    echo "[wifi-connect] Failed -- no IP assigned" | tee -a $LOG
    echo "[wifi-connect] Returning to hotspot..."
    pkill -x wpa_supplicant 2>/dev/null
    pkill -x dhcpcd 2>/dev/null
    rm -f /tmp/wpa-temp.conf
    systemctl restart wlan0-manager.service
    exit 1
fi
