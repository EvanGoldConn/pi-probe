#!/bin/bash
# Owns wlan0 completely.
# On boot, immediately starts NETGEAR_EXT_4786 hotspot -- no exceptions.
# Use wifi-connect to join a local network manually once SSHed in.
# If that connection fails or drops, watchdog returns to hotspot.
# Logs to /tmp/wlan0-manager.log

LOG=/tmp/wlan0-manager.log
MANUAL_FLAG=/tmp/wlan0-manual

log() {
    echo "[wlan0-manager] $1" | tee -a $LOG
}

bring_wlan0_down() {
    # Stop everything that could be touching wlan0
    systemctl stop wpa_supplicant@wlan0.service 2>/dev/null
    systemctl stop wpa_supplicant.service 2>/dev/null
    systemctl stop hostapd 2>/dev/null
    systemctl stop dnsmasq 2>/dev/null
    pkill -x wpa_supplicant 2>/dev/null
    pkill -x dhcpcd 2>/dev/null
    # Stop networkd DHCP on wlan0 -- it will reassign IPs if left running
    networkctl down wlan0 2>/dev/null
    ip link set wlan0 down
    ip addr flush dev wlan0
    rm -f /var/run/wpa_supplicant/wlan0 2>/dev/null
    sleep 2
}

start_hotspot() {
    log "Starting hotspot mode..."
    bring_wlan0_down

    # Wait for wlan0 to be ready -- Alfa adapter initialization can
    # briefly interfere with the wireless subsystem on boot
    for i in 1 2 3 4 5; do
        if ip link show wlan0 | grep -q "state UP\|state DOWN"; then
            break
        fi
        sleep 2
    done

    ip addr add 192.168.4.1/24 dev wlan0
    ip link set wlan0 up

    # Retry hostapd up to 5 times -- wlan0 may not be ready immediately
    systemctl unmask hostapd 2>/dev/null
    for i in 1 2 3 4 5; do
        systemctl start hostapd
        sleep 3
        if systemctl is-active --quiet hostapd; then
            systemctl start dnsmasq
            log "Hotspot active -- SSID: NETGEAR_EXT_4786, IP: 192.168.4.1"
            return 0
        fi
        log "hostapd attempt $i failed -- retrying..."
        systemctl stop hostapd 2>/dev/null
        sleep 2
    done
    log "ERROR: hostapd failed to start after 5 attempts"
}

check_connectivity() {
    IP=$(ip addr show wlan0 2>/dev/null | grep "inet " | awk '{print $2}')
    if [ -z "$IP" ]; then
        return 1
    fi
    # Hotspot mode is always considered connected
    if echo "$IP" | grep -q "192.168.4.1"; then
        return 0
    fi
    # wifi-connect session -- ping the actual assigned gateway
    GATEWAY=$(ip route show dev wlan0 2>/dev/null | grep default | awk '{print $3}')
    if [ -z "$GATEWAY" ]; then
        return 1
    fi
    ping -c 2 -W 3 "$GATEWAY" -I wlan0 > /dev/null 2>&1
    return $?
}

# Boot delay -- 20s to allow Alfa adapter and wireless subsystem to
# fully initialize before we attempt to start hostapd
log "Started at $(date) -- waiting 20s for system init..."
sleep 20

log "Boot: starting hotspot immediately"
start_hotspot

# Watchdog loop
while true; do
    sleep 30

    if check_connectivity; then
        if [ -f "$MANUAL_FLAG" ]; then
            log "Manual connection active ($(cat $MANUAL_FLAG)) -- not interfering"
        fi
        continue
    fi

    if [ -f "$MANUAL_FLAG" ]; then
        log "Manual connection lost -- returning to hotspot"
        rm -f "$MANUAL_FLAG"
    else
        log "Connectivity lost -- returning to hotspot"
    fi

    start_hotspot
done
